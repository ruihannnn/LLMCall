#
# 没有注释的环境变量为必需变量
# 带注释的环境变量为可选变量，默认值为注释中的值
#

# ==============LLM配置==============
LLM_URL=http://<>:1688/v1/

# # 如果是本地部署的模型，那么不需要API_KEY
# API_KEY=test

# MODEL_NAME=qwen
# TEMPERATURE=0.6
# TOP_P=0.95
# MAX_TOKENS=100000
# STOP=["<|endoftext|>"]

# ==============数据集配置==============
# 输入文件的绝对路径
INPUT_PATH=/mnt/volumes/base-cv-ali-sh/minghuizheng/data_cleaning/dpo_distill/dataset/example/dpo_v1_0624_trans.jsonl

# 输出文件的绝对路径
OUTPUT_PATH=/mnt/volumes/base-cv-ali-sh/liruihan/llm_distill_tool_v2/data/test.jsonl

# 提取哪几列的数据
INPUT_COLUMNS=session,query

# 输出到哪一列
OUTPUT_COLUMN=assistant_new

# # 若OUTPUT_PROMPT_COLUMN非空，那么将填充后的prompt输出到OUTPUT_PROMPT_COLUMN列中;如果为空，那么不输出prompt
# OUTPUT_PROMPT_COLUMN=

# BATCH_SIZE=1000

# # 一个问题生成多少个不同的答案
# NUM_RESPONSES=1

# 如果MAX_ROWS非空，那么仅仅处理输入文件中前MAX_ROWS行的数据；如果为空，那么处理全部数据
# MAX_ROWS=5

# MAX_CONCURRENT_TASKS=512

# ==============Prompt配置==============
# 使用 prompt.py 文件中的 prompt 模板，即 all_prompt_dict [PROMPT_EKY]

# --------------同时传入多个Prompt------------------
# 若PROMPT_KEY为多个，例如PROMPT_KEY=prompt1,prompt2，那么

# 若OUTPUT_COLUMN=output1,output2，会将llm对于prompt1的回答以str格式输出到output1列中，将prompt2的回答以str格式输出到output2列中
# 若OUTPUT_PROMPT_COLUMN=output_prompt1,output_prompt2，会将填充后的prompt1以str格式输出到output_prompt1中，将填充后的prompt2以str格式输出到output_prompt2中

# 若OUTPUT_COLUMN=output，会以[对prompt1的回答，对prompt2的回答]的格式输出到output列中
# 若OUTPUT_PROMPT_COLUMN=output_prompt，会以[填充后的prompt1，填充后的prompt2]的格式输出到output_prompt中
# --------------------------------

PROMPT_KEY=generate_assistant_new

# ==============回调函数配置==============
# 在 response_processor.py 中选择要使用的回调函数（只需将函数名填写至下方即可）
RESPONSE_PROCESSOR=no_think_response_processor